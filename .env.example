# ── Copy to .env for local development ───────────────────────────────────────
# On Render, set these as Environment Variables in the dashboard.

# Database
# Local:   sqlite:///./sujas.db
# Supabase: postgresql://postgres:[YOUR-PASSWORD]@db.capknypjhsappsakutmd.supabase.co:5432/postgres
DATABASE_URL=sqlite:///./sujas.db

# JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret

# Token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20

# Comma-separated list of allowed frontend origins
# Local:  http://localhost:3000,http://localhost:5173
# Render: https://your-frontend.onrender.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Set to 1 only when creating the first admin account, then remove
ALLOW_REGISTER=0
